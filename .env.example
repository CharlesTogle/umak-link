# Frontend (Vite)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Backend API URL (development: http://localhost:8080)
VITE_API_URL=http://localhost:8080

# Supabase (public values only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON=your_supabase_anon_key

# Optional rate limiting for client-side metadata requests
VITE_MAX_METADATA_REQUESTS_PER_MINUTE=5
